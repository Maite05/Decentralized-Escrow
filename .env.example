# ─── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix).
DEPLOYER_PRIVATE_KEY=
# Public address of the deployer — required by verify.ts.
DEPLOYER_ADDRESS=

# ─── Agent / Agentic Wallet ────────────────────────────────────────────────────
# Separate key for the autonomous agent wallet (mediator + fee collector).
# Fund this address with testnet OKB from https://www.okx.com/xlayer/faucet
AGENT_PRIVATE_KEY=

# ─── OKX API (DEX SDK + Onchain OS Wallet API) ────────────────────────────────
# Get credentials from https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# USDC address on X Layer testnet (used for fee swaps by the agent).
TESTNET_USDC_ADDR=

# Address of the deployed MilestoneEscrow contract the agent should monitor.
ESCROW_CONTRACT_ADDR=

# ─── RPC URLs (server-side, used by Hardhat) ───────────────────────────────────
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
POLYGON_RPC_URL=
MUMBAI_RPC_URL=

# ─── Block Explorer ────────────────────────────────────────────────────────────
POLYGONSCAN_API_KEY=
OKLINK_API_KEY=

# ─── Token Addresses ───────────────────────────────────────────────────────────
# ERC-20 token address used for mediator staking in MediatorRegistry.
STAKE_TOKEN_ADDRESS=

# ─── Protocol Fee ──────────────────────────────────────────────────────────────
# Wallet that receives the 5% protocol fee on each milestone release.
# Defaults to the deployer address if not set.
FEE_RECIPIENT=

# ─── Backend ───────────────────────────────────────────────────────────────────
API_PORT=4000
# PostgreSQL — get a free URL from Neon (neon.tech), Supabase, or Railway.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/escrow_db
FRONTEND_URL=http://localhost:3000

# Redis connection for BullMQ notification queue.
# If unset the backend falls back to an in-memory queue.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── Frontend (NEXT_PUBLIC_* are exposed to the browser) ───────────────────────
# Base URL of the backend API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Target chain ID for the dApp:
#   196   = X Layer mainnet
#   1952  = X Layer testnet (default)
#   137   = Polygon mainnet
#   80001 = Polygon Mumbai
NEXT_PUBLIC_TARGET_CHAIN_ID=1952

# RPC URLs — leave blank to use public defaults.
NEXT_PUBLIC_XLAYER_RPC_URL=
NEXT_PUBLIC_POLYGON_RPC_URL=
NEXT_PUBLIC_MUMBAI_RPC_URL=

# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# USDC contract address on the target chain.
NEXT_PUBLIC_USDC_ADDRESS=

# Contract addresses (auto-populated by deploy script → contracts/shared/addresses.json).
NEXT_PUBLIC_ESCROW_FACTORY_ADDRESS=
