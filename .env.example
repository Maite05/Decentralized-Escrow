# ─── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix)
DEPLOYER_PRIVATE_KEY=

# ─── RPC URLs ──────────────────────────────────────────────────────────────────
POLYGON_RPC_URL=
MUMBAI_RPC_URL=

# ─── Block Explorer ────────────────────────────────────────────────────────────
POLYGONSCAN_API_KEY=

# ─── Token Addresses ───────────────────────────────────────────────────────────
# Stake token address used by MediatorRegistry
STAKE_TOKEN_ADDRESS=

# ─── Frontend (NEXT_PUBLIC_* are exposed to the browser) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_POLYGON_RPC_URL=
NEXT_PUBLIC_MUMBAI_RPC_URL=
NEXT_PUBLIC_TARGET_CHAIN_ID=80001
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
