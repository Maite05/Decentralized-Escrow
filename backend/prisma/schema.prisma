generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  FREELANCER
  MEDIATOR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  LOCKED
  DELIVERED
  RELEASED
  DISPUTED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  role          Role     @default(CLIENT)
  email         String?
  createdAt     DateTime @default(now())

  clientProjects     Project[]     @relation("ClientProjects")
  freelancerProjects Project[]     @relation("FreelancerProjects")
  mediatedDisputes   Dispute[]     @relation("MediatorDisputes")
  postedJobs         Job[]         @relation("PostedJobs")
  applications       Application[]
}

model Project {
  id            String        @id @default(cuid())
  escrowAddress String        @unique
  clientId      String
  freelancerId  String
  status        ProjectStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client     User        @relation("ClientProjects", fields: [clientId], references: [id])
  freelancer User        @relation("FreelancerProjects", fields: [freelancerId], references: [id])
  milestones Milestone[]
  dispute    Dispute?
}

model Milestone {
  id                  String          @id @default(cuid())
  projectId           String
  milestoneIndex      Int
  description         String
  amount              String
  status              MilestoneStatus @default(LOCKED)
  freelancerDelivered Boolean         @default(false)
  clientApproved      Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, milestoneIndex])
}

model Job {
  id           String    @id @default(cuid())
  clientId     String
  title        String
  description  String
  budget       String
  skills       String[]
  status       JobStatus @default(OPEN)
  escrowAddress String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client       User          @relation("PostedJobs", fields: [clientId], references: [id])
  applications Application[]
}

model Application {
  id           String   @id @default(cuid())
  jobId        String
  freelancerId String
  coverLetter  String
  createdAt    DateTime @default(now())

  job        Job  @relation(fields: [jobId], references: [id])
  freelancer User @relation(fields: [freelancerId], references: [id])

  @@unique([jobId, freelancerId])
}

model Dispute {
  id             String        @id @default(cuid())
  projectId      String        @unique
  milestoneIndex Int
  raisedBy       String
  mediatorId     String?
  status         DisputeStatus @default(OPEN)
  resolution     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project  Project @relation(fields: [projectId], references: [id])
  mediator User?   @relation("MediatorDisputes", fields: [mediatorId], references: [id])
}
