generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  FREELANCER
  MEDIATOR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  LOCKED
  DELIVERED
  RELEASED
  DISPUTED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Availability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  INTERVIEWING
  REJECTED
  HIRED
}

model User {
  id                String       @id @default(cuid())
  walletAddress     String       @unique
  role              Role         @default(CLIENT)
  email             String?
  // Freelancer profile fields
  displayName       String?
  tagline           String?      // One-liner: "Full-stack Web3 developer"
  bio               String?
  skills            String[]     @default([])
  portfolioUrl      String?
  hourlyRate        String?      // USDC per hour, stored as string
  availability      Availability @default(AVAILABLE)
  rating            Float?       // 0.0 – 5.0 average
  completedProjects Int          @default(0)
  totalEarned       String?      // Cumulative USDC earned, stored as string
  createdAt         DateTime     @default(now())

  clientProjects     Project[]       @relation("ClientProjects")
  freelancerProjects Project[]       @relation("FreelancerProjects")
  mediatedDisputes   Dispute[]       @relation("MediatorDisputes")
  postedJobs         Job[]           @relation("PostedJobs")
  applications       Application[]
  portfolioItems     PortfolioItem[]
}

model PortfolioItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  imageUrl    String?
  projectUrl  String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id              String        @id @default(cuid())
  escrowAddress   String        @unique
  clientId        String
  freelancerId    String
  mediatorAddress String?
  status          ProjectStatus @default(ACTIVE)
  title               String?
  description         String?
  totalAmount         String?
  deadline            DateTime?
  freelancerAccepted  Boolean   @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client     User        @relation("ClientProjects", fields: [clientId], references: [id])
  freelancer User        @relation("FreelancerProjects", fields: [freelancerId], references: [id])
  milestones Milestone[]
  dispute    Dispute?
}

model Milestone {
  id                  String          @id @default(cuid())
  projectId           String
  milestoneIndex      Int
  description         String
  amount              String
  status              MilestoneStatus @default(LOCKED)
  dueDate             DateTime?
  freelancerDelivered Boolean         @default(false)
  clientApproved      Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, milestoneIndex])
}

model Job {
  id            String    @id @default(cuid())
  clientId      String
  title         String
  description   String
  budget        String
  skills        String[]
  status        JobStatus @default(OPEN)
  escrowAddress String?
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client       User          @relation("PostedJobs", fields: [clientId], references: [id])
  applications Application[]
}

model Application {
  id                 String            @id @default(cuid())
  jobId              String
  freelancerId       String
  coverLetter        String
  status             ApplicationStatus @default(PENDING)
  interviewNote      String?           // Client's note after interview
  proposedMilestones Json?             // Freelancer's proposed stages: [{description, amount, dueDate?}]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  job        Job  @relation(fields: [jobId], references: [id])
  freelancer User @relation(fields: [freelancerId], references: [id])

  @@unique([jobId, freelancerId])
}

model Dispute {
  id             String        @id @default(cuid())
  projectId      String        @unique
  milestoneIndex Int
  raisedBy       String
  mediatorId     String?
  status         DisputeStatus @default(OPEN)
  resolution     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project  Project @relation(fields: [projectId], references: [id])
  mediator User?   @relation("MediatorDisputes", fields: [mediatorId], references: [id])
}
